{
  "compilerOptions": {
    "module": "commonjs",
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "../out/main",
    "rootDir": ".",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "target": "ES2022",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true
  },
  "files": [
    "browser-config.ts",
    "menu.ts",
    "main.ts",
    "preload.ts",
    "lib.d.ts"
  ]
}
